{
  "name": "chromectx",
  "version": "0.1.0",
  "description": "macOS CLI and MCP server for Chrome tab context",
  "author": {
    "name": "Anubhav Saha",
    "url": "https://github.com/dyingg"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dyingg/chromectx"
  },
  "homepage": "https://github.com/dyingg/chromectx",
  "bugs": {
    "url": "https://github.com/dyingg/chromectx/issues"
  },
  "keywords": [
    "chrome",
    "tabs",
    "mcp",
    "macos",
    "cli",
    "context",
    "model-context-protocol"
  ],
  "type": "module",
  "os": [
    "darwin"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "bin": {
    "chromectx": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "prepublishOnly": "bun run build",
    "dev": "bun run src/bin/cli.ts",
    "doctor": "bun run src/bin/cli.ts doctor",
    "mcp": "bun run src/bin/cli.ts mcp",
    "mcp:inspect": "npx @modelcontextprotocol/inspector bun run src/bin/cli.ts mcp",
    "lint": "biome ci --error-on-warnings .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "test:unit": "bun test test/unit",
    "test:integration": "bun test test/integration",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "turndown": "^7.2.2",
    "wink-bm25-text-search": "^3.1.2",
    "wink-nlp-utils": "^2.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.15.18",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.8.3"
  }
}
